# =============================================================================
# Proton Drive Sync - Docker Environment Configuration
# =============================================================================

# Required: Encryption key for credential storage
# Generate a secure key with: openssl rand -base64 32
KEYRING_PASSWORD=

# Optional: Timezone (default: UTC)
TZ=UTC

# Optional: Dashboard port on host (default: 4242)
DASHBOARD_PORT=4242

# Host directory mount points: map directories from your host filesystem into
# the Docker container at /data/<name> so the app can access and sync them.
# The actual sync configuration (which directories to watch and where to upload
# them on Proton Drive) is done via the dashboard or CLI after starting the container.
SYNC_DIR_1=/path/to/your/documents
SYNC_DIR_2=/path/to/your/photos

# To add more sync directories, edit docker-compose.yml and add:
#   - ${SYNC_DIR_3:-./data/videos}:/data/videos
# Then set SYNC_DIR_3 here

# Optional: Headless authentication (skip interactive docker exec)
# Note: Does NOT support accounts with 2FA/TOTP enabled
# PROTON_USERNAME=
# PROTON_PASSWORD=
